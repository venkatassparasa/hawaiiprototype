# Development Environment Configuration
NODE_ENV=development
LOG_LEVEL=debug

# Database Configuration
MONGODB_URI=mongodb://admin:password123@localhost:27017/hawaii-tvr-dashboard?authSource=admin
REDIS_URL=redis://:redis123@localhost:6379

# PostgreSQL Configuration (for Temporal)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=temporal
POSTGRES_PASSWORD=temporal
POSTGRES_DB=temporal

# Temporal Configuration
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_UI_PORT=8088

# Azure Storage (Local Emulator)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=hawaiitvrdev;AccountKey=hawaiitvrkey123;BlobEndpoint=http://localhost:10000/devstoreaccount1;QueueEndpoint=http://localhost:10001/devstoreaccount1;TableEndpoint=http://localhost:10002/devstoreaccount1;
AZURE_STORAGE_CONTAINER_NAME=dashboard-evidence

# Authentication
JWT_SECRET=dev-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=24h

# API Configuration
CRAWLER_API_URL=http://localhost:3002
CRAWLER_API_KEY=dev-crawler-api-key

# Frontend Configuration
REACT_APP_API_BASE_URL=http://localhost:3001
REACT_APP_CRAWLER_API_URL=http://localhost:3002
REACT_APP_CRAWLER_API_KEY=dev-crawler-api-key
REACT_APP_TEMPORAL_ENABLED=true

# Development Settings
CHOKIDAR_USEPOLLING=true
GENERATE_SOURCEMAP=true
FAST_REFRESH=true

# Server Configuration
PORT=3001
HOST=0.0.0.0

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# Session Configuration
SESSION_SECRET=dev-session-secret-key
SESSION_MAX_AGE=86400000

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Email Configuration (for development)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@hawaiicounty.gov

# Monitoring Configuration
ENABLE_METRICS=true
METRICS_PORT=9090

# Logging Configuration
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5

# Development Tools
ENABLE_SWAGGER=true
ENABLE_GRAPHQL_PLAYGROUND=true
